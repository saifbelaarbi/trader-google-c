# Cloud Run relay (set in GCP Secret Manager, not here)
WEBHOOK_SECRET=your_webhook_secret_here

# ── Agent — copy relevant vars to agent/.env on your PC ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...
BINANCE_API_KEY=your_testnet_api_key
BINANCE_API_SECRET=your_testnet_api_secret
TRADING_MODE=testnet

# GCP credentials for Firestore access from your local PC
# Option A: point at a downloaded service-account JSON key
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/tradingbot-sa-key.json
# Option B: run once: gcloud auth application-default login
