{
    "bot_name": "claude-consensus-paper",
    "dry_run": true,
    "dry_run_wallet": 200,
    "max_open_trades": 4,
    "stake_currency": "USDT",
    "stake_amount": "unlimited",
    "tradable_balance_ratio": 0.99,
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "cancel_open_orders_on_exit": false,
    "exchange": {
        "name": "bybit",
        "key": "",
        "secret": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "BTC/USDT:USDT",
            "ETH/USDT:USDT",
            "SOL/USDT:USDT",
            "XRP/USDT:USDT",
            "BNB/USDT:USDT",
            "DOGE/USDT:USDT",
            "ADA/USDT:USDT",
            "LINK/USDT:USDT",
            "AVAX/USDT:USDT"
        ],
        "pair_blacklist": []
    },
    "pairlists": [
        {"method": "StaticPairList"}
    ],
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "unfilledtimeout": {
        "entry": 10,
        "exit": 10,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },
    "telegram": {
        "enabled": false,
        "token": "REPLACE_WITH_NEW_BOT_TOKEN",
        "chat_id": "REPLACE_WITH_YOUR_CHAT_ID",
        "notification_settings": {
            "status": "on",
            "warning": "on",
            "entry": "on",
            "exit": "on",
            "entry_fill": "on",
            "exit_fill": "on",
            "protection_trigger": "on",
            "protection_trigger_global": "on"
        }
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "127.0.0.1",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": false,
        "jwt_secret_key": "REPLACE_WITH_RANDOM_STRING",
        "ws_token": "REPLACE_WITH_RANDOM_STRING",
        "CORS_origins": [],
        "username": "trader",
        "password": "REPLACE_WITH_PASSWORD"
    },
    "_comment_webhook": "Telemetry bridge: posts events to the Cloud Run relay -> Firestore so a cloud Claude session can read live bot state. Set enabled:true, fill url with your relay /ft-event, and X-Webhook-Secret with the relay WEBHOOK_SECRET. Observation only — does not affect trading.",
    "webhook": {
        "enabled": false,
        "url": "https://REPLACE_WITH_RELAY_HOST/ft-event",
        "format": "json",
        "webhook_headers": {
            "X-Webhook-Secret": "REPLACE_WITH_RELAY_WEBHOOK_SECRET"
        },
        "entry_fill": {
            "type": "entry_fill",
            "trade_id": "{trade_id}",
            "pair": "{pair}",
            "direction": "{direction}",
            "open_rate": "{open_rate}",
            "amount": "{amount}",
            "enter_tag": "{enter_tag}"
        },
        "exit_fill": {
            "type": "exit_fill",
            "trade_id": "{trade_id}",
            "pair": "{pair}",
            "direction": "{direction}",
            "close_rate": "{close_rate}",
            "profit_amount": "{profit_amount}",
            "profit_ratio": "{profit_ratio}",
            "exit_reason": "{exit_reason}"
        },
        "status": {
            "type": "status",
            "status": "{status}"
        }
    },
    "initial_state": "running",
    "internals": {
        "process_throttle_secs": 5
    }
}
